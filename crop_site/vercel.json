{
  "builds": [
    {
      "src": "crop_site/wsgi.py",
      "use": "@vercel/python",
      "config": {"maxLambdaSize" : "15mb", "runtime": "python3.14.3" }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "crop_site/wsgi.py"
    }
  ]
}